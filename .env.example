# ─── NVIDIA AI API ───────────────────────────────────────────────────────────
# Get your free key at: https://build.nvidia.com/models
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NVIDIA model to use (pick any from https://build.nvidia.com/models)
# Examples:
#   minimaxai/minimax-m2.7
#   deepseek-ai/deepseek-r1
#   moonshotai/kimi-k2
#   nvidia/llama-3.3-nemotron-super-49b-v1
NVIDIA_MODEL=deepseek-ai/deepseek-r1

# ─── WEB SEARCH (optional but recommended for real-time results) ─────────────
# Option A: Brave Search API — https://api.search.brave.com (free tier: 2000/mo)
BRAVE_SEARCH_API_KEY=

# Option B: Serper.dev — https://serper.dev (free tier: 2500 searches)
SERPER_API_KEY=

# Option C: Tavily AI Search — https://tavily.com (free tier: 1000 calls/mo)
TAVILY_API_KEY=
